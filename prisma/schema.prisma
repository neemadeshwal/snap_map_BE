// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js" // change the provide to -js
}

datasource db {
  provider = "postgresql"
}

enum ConnectionStatus {
  PENDING
  CONNECTED
  DECLINED
  BLOCKED
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
}

model User {
  id         String   @id @default(uuid())
  username   String   @unique
  bio        String?
  profileUrl String?
  city       String?
  latitude   Float?
  longitude  Float?
  interests  String[]
  fcmToken   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  moments             Moment[]
  sentConnections     Connection[]   @relation("Requester")
  receivedConnections Connection[]   @relation("Receiver")
  sentMessages        Message[]
  sentGroupMessages   GroupMessage[]
  groupMembers        GroupMember[]
  conversationsAsP1   Conversation[] @relation("Participant1")
  conversationsAsP2   Conversation[] @relation("Participant2")
}

model Moment {
  id        String                                @id @default(uuid())
  userId    String
  caption   String?
  mediaUrl  String
  category  String
  latitude  Float
  longitude Float
  location  Unsupported("geometry(Point, 4326)")?

  expiresAt       DateTime
  archived        Boolean   @default(false)
  archivedAt      DateTime?
  goingCount      Int       @default(0)
  interestedCount Int       @default(0)
  likeCount       Int       @default(0)
  createdAt       DateTime  @default(now())

  user     User            @relation(fields: [userId], references: [id])
  hashtags MomentHashtag[]

  @@index([location], name: "moment_location_idx", type: Gist)
  @@index([userId])
  @@index([expiresAt])
  @@index([category])
  @@index([archived])
  @@index([userId, archived, expiresAt], name: "Moment_userId_archived_expiresAt_idx")
}

model Hashtag {
  id      String          @id @default(uuid())
  name    String          @unique
  moments MomentHashtag[]
}

model MomentHashtag {
  momentId  String
  hashtagId String

  moment  Moment  @relation(fields: [momentId], references: [id])
  hashtag Hashtag @relation(fields: [hashtagId], references: [id])

  @@id([momentId, hashtagId])
}

model Connection {
  id          String           @id @default(uuid())
  requesterId String
  receiverId  String
  status      ConnectionStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("Requester", fields: [requesterId], references: [id])
  receiver  User @relation("Receiver", fields: [receiverId], references: [id])

  @@unique([requesterId, receiverId])
  @@index([requesterId])
  @@index([receiverId])
}

model Conversation {
  id             String @id @default(uuid())
  participant1Id String
  participant2Id String

  lastMessageText String?
  lastMessageAt   DateTime?
  createdAt       DateTime  @default(now())
  participant1    User      @relation("Participant1", fields: [participant1Id], references: [id])
  participant2    User      @relation("Participant2", fields: [participant2Id], references: [id])
  messages        Message[]

  @@unique([participant1Id, participant2Id])
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  senderId       String
  text           String?
  mediaUrl       String?
  type           MessageType @default(TEXT)
  isRead         Boolean     @default(false)
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([createdAt])
}

model GroupConversation {
  id        String   @id @default(uuid())
  name      String
  createdBy String
  momentId  String?
  createdAt DateTime @default(now())

  members  GroupMember[]
  messages GroupMessage[]
}

model GroupMember {
  groupId  String
  userId   String
  joinedAt DateTime @default(now())

  group GroupConversation @relation(fields: [groupId], references: [id])
  user  User              @relation(fields: [userId], references: [id])

  @@id([groupId, userId])
}

model GroupMessage {
  id        String      @id @default(uuid())
  groupId   String
  senderId  String
  text      String?
  mediaUrl  String?
  type      MessageType @default(TEXT)
  createdAt DateTime    @default(now())

  group  GroupConversation @relation(fields: [groupId], references: [id])
  sender User              @relation(fields: [senderId], references: [id])
}
